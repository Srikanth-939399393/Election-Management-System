     			(
	     			  type = country
	     			  displayname = "Country"
	     			 visibility = false
     			) 
     			latitude
     			(
	     			  type = latitude
	     			  displayname = "Latitude"
	     			 visibility = false
     			) 
     			longitude
     			(
	     			  type = longitude
	     			  displayname = "Longitude"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = medium
			)
			ward_constituency
			(
				type = list	
				displayname = "Ward / Constituency"
				values  = constituency_ward.ID
    			displayformat = [constituency_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			phone_number
			(
    			type = phonenumber
				displayname = "Phone Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			email
			(
    			type = email
				displayname = "Email"
	 			row = 1
	 			column = 1   
				width = medium
			)
			national_id_aadhaar
			(
    			type = text
				displayname = "National ID / Aadhaar Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			id_proof_type
			(
				type = picklist
				displayname = "ID Proof Type"
				values = {"Passport","Aadhaar","Driving License","Voter Card"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			id_proof_number
			(
    			type = text
				displayname = "ID Proof Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			photo_upload
			(
    			type = url
				displayname = "Photo Upload"
	 			row = 1
	 			column = 1   
				width = medium
			)
			id_proof_document
			(
    			type = url
				displayname = "ID Proof Document Upload"
	 			row = 1
	 			column = 1   
				width = medium
			)
			otp_verified
			(
    			type = checkbox
				displayname = "OTP Verified?"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			registration_status
			(
				type = picklist
				displayname = "Registration Status"
				values = {"Approved","Rejected","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			rejection_reason
			(
    			type = textarea
				displayname = "Rejection Reason"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			assigned_polling_booth
			(
				type = list	
				displayname = "Assigned Polling Booth"
				values  = polling_booth.ID
    			displayformat = [booth_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			registered_on
			(
    			type = datetime
				displayname = "Registered On"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			approved_by
			(
    			type = text
				displayname = "Approved By"
	 			row = 1
	 			column = 1   
				width = medium
			)
			approved_on
			(
    			type = datetime
				displayname = "Approved On"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Registration Initiated","Document Verification Pending","Registration Draft Saved","OTP Verification Pending","Registration Rejected","Registration Under Review","Registration Approved","Additional Verification Required","Polling Booth Assigned","Registration Finalized","Registration Closed"}
			}
		}
	}
	reports
	{
		list vote_count_submission_Report
		{
			displayName = "All Vote Count Submissions"
