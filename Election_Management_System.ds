 application "Election Management System"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form ballot_configuration
		{
			displayname = "Ballot Configuration"
			success message = "Ballot Configuration Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			election
			(
				type = list	
				displayname = "Election"
				values  = election_configuration.ID
    			displayformat = [election_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			constituency
			(
				type = list	
				displayname = "Constituency"
				values  = constituency_ward.ID
    			displayformat = [constituency_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			ballot_serial_number
			(
    			type = text
				displayname = "Ballot Serial Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			candidate_list
			(
    			type = textarea
				displayname = "Candidate List"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			nota_enabled
			(
    			type = checkbox
				displayname = "NOTA Option Enabled?"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			ballot_status
			(
				type = picklist
				displayname = "Ballot Status"
				values = {"Locked","Draft","Published"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form candidate_registration
		{
			displayname = "Candidate Registration"
