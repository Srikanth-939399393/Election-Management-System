			)
			approved_on
			(
    			type = datetime
				displayname = "Approved On"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Candidate Registration Submitted","Document Verification Pending","Candidate Registration Rejected","Criminal Background Check Pending","Asset and Affidavit Verification Pending","Criminal Background Verified","Criminal Background Under Review","Asset and Affidavit Verified","Nomination Status Pending Approval","Nomination Approved","Candidate Registration Finalized"}
