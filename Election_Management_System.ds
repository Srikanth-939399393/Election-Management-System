		{
			displayName = "Nomination Statuses"
			show all rows from candidate_registration    
			(
				election as "Election"
				full_name  as "Full Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				date_of_birth as "Date Of Birth"
				gender as "Gender"
				party_name as "Party Name"
				independent_candidate as "Independent Candidate?"
				party_symbol as "Party Symbol Upload"
				candidate_photo as "Candidate Photo Upload"
				constituency as "Constituency"
				phone_number as "Phone Number"
				email as "Email"
				national_id_aadhaar as "National ID / Aadhaar Number"
				nomination_document as "Nomination Document Upload"
				affidavit as "Affidavit Upload"
				asset_declaration as "Asset Declaration Document Upload"
				criminal_background_declaration as "Criminal Background Declaration Upload"
				has_criminal_record as "Has Criminal Record?"
				criminal_case_details as "Criminal Case Details"
				nomination_status as "Nomination Status"
				rejection_reason as "Rejection Reason"
				registered_on as "Registered On"
				approved_by as "Approved By"
				approved_on as "Approved On"
			)
			options
			(
	 			display field = nomination_status
	 		)
		}
		list document_management_Report
		{
			displayName = "All Document Management"
			show all rows from document_management    
			(
				election as "Election"
				record_type as "Record Type"
				record_id as "Record ID"
				document_type as "Document Type"
				document_url as "Document URL"
				upload_date as "Upload Date"
				status as "Status"
				notes as "Notes"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (record_type == "Candidate")
				fields = [record_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (record_type == "Officer")
				fields = [record_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (record_type == "Voter")
				fields = [record_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban document_management_by_document_type
		{
			displayName = "Document Types"
			show all rows from document_management    
			(
				election as "Election"
				record_type as "Record Type"
				record_id as "Record ID"
				document_type as "Document Type"
				document_url as "Document URL"
				upload_date as "Upload Date"
				status as "Status"
				notes as "Notes"
			)
			options
			(
	 			display field = document_type
	 		)
		}
	}
	pages
	{
		page DashBoard
